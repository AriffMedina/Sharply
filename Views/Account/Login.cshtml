@using Sharply.Web.ViewModels
@model LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Sign In";
}

<head>
    <link href="~/css/auth.css" rel="stylesheet" />
</head>

<div class="auth-shell">
    <div class="auth-logo">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z" /></svg>
        Sharply
    </div>

    <div class="auth-card">
        <div class="auth-title">Welcome back</div>
        <div class="auth-subtitle">Sign in to keep your skills sharp.</div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="auth-error-summary">
                @foreach (var error in ViewData.ModelState[""]!.Errors)
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
            @Html.AntiForgeryToken()

            <div class="auth-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" placeholder="you@example.com" autocomplete="username" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="btn-primary auth-submit">Sign In</button>
        </form>

        <div class="auth-switch">
            Don't have an account? <a asp-controller="Account" asp-action="Register">Create one</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}