@using Sharply.Web.ViewModels
@model RegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Create Account";
}

<head>
    <link href="~/css/auth.css" rel="stylesheet" />
</head>

<div class="auth-shell">
    <div class="auth-logo">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z" /></svg>
        Sharply
    </div>

    <div class="auth-card">
        <div class="auth-title">Create your account</div>
        <div class="auth-subtitle">Start tracking and sharpening your skills.</div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="auth-error-summary">
                @foreach (var error in ViewData.ModelState[""]!.Errors)
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Register">
            @Html.AntiForgeryToken()

            <div class="auth-field">
                <label asp-for="Name">Full name</label>
                <input asp-for="Name" type="text" placeholder="Jordan Hayes" autocomplete="name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="ConfirmPassword">Confirm password</label>
                <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-primary auth-submit">Create Account</button>
        </form>

        <div class="auth-switch">
            Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
