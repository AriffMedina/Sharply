@model List<Sharply.Web.ViewModels.SkillCardViewModel>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Skills";
}

@functions {
    string MasteryClass(string mastery) => mastery.Trim().ToLowerInvariant() switch
    {
        "sharp" => "sharp",
        "rusty" => "rusty",
        _ => "intermediate"
    };
    string PriorityClass(string priority) => priority.Trim().ToLowerInvariant() switch
    {
        "high" => "high",
        "low" => "low",
        _ => "medium"
    };
    string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : name.Substring(0, Math.Min(2, name.Length));
    }
}

<head><link href="~/css/skill-index.css" rel="stylesheet" /></head>

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z" /></svg>
            Sharply
        </div>
        <ul class="sidebar-nav">
            <li>
                <a asp-controller="Home" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                    Dashboard
                </a>
            </li>
            <li>
                <a asp-controller="Skills" asp-action="Index" class="active">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z" /></svg>
                    Skills
                </a>
            </li>
            <li>
                <a href="#">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z" /><path d="M5 4H3v2a3 3 0 0 0 3 3M19 4h2v2a3 3 0 0 1-3 3" /></svg>
                    Challenges
                </a>
            </li>
            <li>
                <a href="#">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4" /><path d="M2 21v-2a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v2" /></svg>
                    Community
                </a>
            </li>
            <li>
                <a href="#">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 18.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 14a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 8a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 8.93 3.6V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                    Settings
                </a>
            </li>
        </ul>
    </aside>

    <main class="main">
        <div class="topbar">
            <div class="search-box">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.35-4.35" /></svg>
                <span>Search your skills...</span>
            </div>
        </div>

        <div class="section-header">
            <div>
                <div class="section-title-row">
                    <span class="section-title">My Skills</span>
                    <span class="section-badge">@Model.Count Total</span>
                </div>
                <div class="section-subtitle">Gestiona, edita o elimina tus skills.</div>
            </div>
            <div class="section-actions">
                <a class="btn-primary" asp-controller="Skills" asp-action="Create">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" /></svg>
                    Add Skill
                </a>
            </div>
        </div>

        @if (TempData["SkillUpdated"] != null)
        {
            <div class="skill-toast skill-toast--ok">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5" /></svg>
                "@TempData["SkillUpdated"]" actualizado correctamente.
            </div>
        }
        @if (TempData["SkillDeleted"] != null)
        {
            <div class="skill-toast skill-toast--err">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /></svg>
                "@TempData["SkillDeleted"]" eliminado.
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card skills-empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z" /></svg>
                <p>You have no skills logged yet.</p>
                <a class="btn-primary" asp-controller="Skills" asp-action="Create">Add my first skill</a>
            </div>
        }
        else
        {
            <div class="skills-list">
                @foreach (var skill in Model)
                {
                    var mc = MasteryClass(skill.MasteryLevel);
                    var pc = PriorityClass(skill.Priority);
                    var circumference = 2 * Math.PI * 26;
                    var offset = circumference * (1 - skill.RetentionPercent / 100.0);

                    <div class="card skill-list-row">
                        <div class="ring-wrap" style="width:52px;height:52px;flex-shrink:0;">
                            <svg viewBox="0 0 60 60" style="width:52px;height:52px;">
                                <circle class="ring-track" cx="30" cy="30" r="26" />
                                <circle class="ring-progress @mc" cx="30" cy="30" r="26"
                                        stroke-dasharray="@circumference.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                        stroke-dashoffset="@offset.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />
                            </svg>
                            <div class="ring-value @mc" style="font-size:.65rem;">@skill.RetentionPercent%</div>
                        </div>

                        <div class="skill-list-info">
                            <div class="skill-name">@skill.Name</div>
                            <div class="skill-list-meta">
                                <span class="badge @pc">@skill.Priority Priority</span>
                                <span class="meta-item mastery-label @mc">@skill.MasteryLevel</span>
                                <span class="meta-item">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 3" /></svg>
                                    @skill.DaysAgo days ago
                                </span>
                            </div>
                        </div>

                        <div class="skill-list-actions">
                            <a class="btn-sl btn-sl--edit" asp-controller="Skills" asp-action="Edit" asp-route-id="@skill.Id">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                Editar
                            </a>
                            <form method="post" asp-controller="Skills" asp-action="Delete" asp-route-id="@skill.Id"
                                  onsubmit="return confirm('¿Eliminar @skill.Name?')">
                                @Html.AntiForgeryToken()
                                <button class="btn-sl btn-sl--del" type="submit">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6M14 11v6M9 6V4h6v2" /></svg>
                                    Eliminar
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </main>
</div>